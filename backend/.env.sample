# ==========================================
# TASK MANAGER - ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub - it contains secrets!

# ------------------------------------------
# 1. DJANGO CORE SETTINGS
# ------------------------------------------
DEBUG=True
SECRET_KEY=change-this-to-a-50-char-random-string-here-now

# ------------------------------------------
# 2. DATABASE
# ------------------------------------------
# OPTION A: SQLite (for local development - works immediately, no setup needed)
DATABASE_URL=sqlite:///db.sqlite3

# OPTION B: Supabase PostgreSQL (for production/cloud)
# Uncomment the line below and comment out SQLite when ready for production
# Get this from your Supabase dashboard:
# Project Settings > Database > Connection String
# DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# ------------------------------------------
# 3. ALLOWED HOSTS
# ------------------------------------------
ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------------------
# 4. CORS (Frontend URLs)
# ------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ------------------------------------------
# 5. JWT TOKEN SETTINGS
# ------------------------------------------
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=3

# ------------------------------------------
# 6. GOOGLE OAUTH (Backend Verification)
# ------------------------------------------
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=123456789-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret-here

# ------------------------------------------
# 7. SMTP EMAIL (Gmail with App Password)
# ------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
